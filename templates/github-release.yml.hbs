# Generated by livreur init. This file is fully managed.
name: Release

on:
  push:
    tags:
      - "**"
  workflow_dispatch:

jobs:
{{#each jobs}}
  {{id}}:
    name: {{name}}
    runs-on: {{runner}}
    permissions:
      contents: read
    steps:
      - uses: actions/checkout@v6
{{#if ../self_hosting}}
      - name: Build Livreur from checkout
        run: cargo build --release --locked
      - name: Select Livreur executable
        shell: bash
        run: echo "$GITHUB_WORKSPACE/target/release" >> "$GITHUB_PATH"
{{else}}
      - name: Install pinned Livreur
        run: cargo install livreur --version '={{../version}}' --locked
{{/if}}
      - name: Validate release tag
        run: livreur validate --tag "{{{../github_ref_name}}}"
      - name: Build and package {{target}}
        shell: bash
        run: |
          echo "livreur build/package is not implemented yet ({{target}})" >&2
          exit 1
{{/each}}
  publish:
    name: Publish release
    if: {{{publish_condition}}}
    needs: [{{needs}}]
    runs-on: ubuntu-latest
    environment: {{{protected_environment}}}
    permissions:
      contents: write
      id-token: write
    steps:
      - uses: actions/checkout@v6
{{#if self_hosting}}
      - name: Build Livreur from checkout
        run: cargo build --release --locked
      - name: Select Livreur executable
        shell: bash
        run: echo "$GITHUB_WORKSPACE/target/release" >> "$GITHUB_PATH"
{{else}}
      - name: Install pinned Livreur
        run: cargo install livreur --version '={{version}}' --locked
{{/if}}
      - name: Publication unavailable
        run: |
          echo "livreur publish is not implemented yet" >&2
          exit 1
